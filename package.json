{
  "name": "metascore-library",
  "version": "3.6.2",
  "description": "",
  "type": "module",
  "homepage": "http://metascore.philharmoniedeparis.fr",
  "author": "La Cité de la musique - Philharmonie de Paris (https://philharmoniedeparis.fr)",
  "license": "CECILL-2.1",
  "bugs": "https://github.com/philharmoniedeparis/metascore-library/issues",
  "repository": {
    "type": "git",
    "url": "https://github.com/philharmoniedeparis/metascore-library.git"
  },
  "scripts": {
    "prepare": "husky install",
    "dev": "vite",
    "clean": "rimraf dist",
    "build-umd:player": "cross-env BUILD_MODE=umd BUILD_ENTRY=metaScore.Player vite build",
    "build-umd:api": "cross-env BUILD_MODE=umd BUILD_ENTRY=metaScore.API vite build",
    "build-umd:editor": "cross-env BUILD_MODE=umd BUILD_ENTRY=metaScore.Editor vite build",
    "build-umd": "run-p build-umd:player build-umd:api build-umd:editor",
    "build-cjs-es": "vite build",
    "build": "npm run clean & run-p type-check build-cjs-es build-umd",
    "preview": "vite preview",
    "test:unit": "vitest",
    "test:e2e": "start-server-and-test preview http://localhost:4173 'cypress run --e2e'",
    "test:e2e:dev": "start-server-and-test 'vite dev --port 4173' http://localhost:4173 'cypress open --e2e'",
    "type-check": "vue-tsc --build --force",
    "lint": "eslint . --fix",
    "format": "prettier --write src/",
    "release": "commit-and-tag-version",
    "release:patch": "commit-and-tag-version --release-as patch",
    "release:minor": "commit-and-tag-version --release-as minor",
    "release:major": "commit-and-tag-version --release-as major"
  },
  "dependencies": {
    "@blockly/block-plus-minus": "^7.0.0",
    "@blockly/continuous-toolbox": "^5.0.0",
    "@blockly/disable-top-blocks": "^0.4.0",
    "@floating-ui/dom": "^1.0.1",
    "@formkit/auto-animate": "^0.8.1",
    "@interactjs/actions": "^1.10.27",
    "@interactjs/auto-start": "^1.10.27",
    "@interactjs/interact": "^1.10.27",
    "@interactjs/modifiers": "^1.10.27",
    "@interactjs/pointer-events": "^1.10.27",
    "@nx-js/compiler-util": "^2.0.0",
    "ajv": "^8.10.0",
    "ajv-i18n": "^4.2.0",
    "blockly": "^10.0.0",
    "chroma-js": "^2.4.2",
    "ckeditor5": "^43.3.1",
    "core-js": "^3.25.1",
    "dashjs": "^4.2.1",
    "fuse.js": "^7.0.0",
    "geometry-polyfill": "^1.0.7",
    "hammerjs": "^2.0.8",
    "hls.js": "^1.1.5",
    "lodash": "^4.17.21",
    "lottie-web": "^5.8.1",
    "mixwith": "^0.1.1",
    "normalize.css": "^8.0.1",
    "pinia": "^2.2.6",
    "sortablejs": "^1.15.2",
    "source-sans": "github:adobe-fonts/source-sans#3.046R",
    "timecode-input": "github:philharmoniedeparis/timecode-input#v2.0.1",
    "tiny-emitter": "^2.1.0",
    "url-regex": "^5.0.0",
    "uuid": "^9.0.0",
    "v-hotkey": "https://github.com/philharmoniedeparis/v-hotkey/tarball/2587857",
    "validate-color": "2.2.1",
    "vue": "^3.5.12",
    "vue-dompurify-html": "^5.0.0",
    "vue-i18n": "^9.1.9",
    "vue-inline-svg": "^3.1.0",
    "waveform-data": "^4.3.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^17.4.3",
    "@commitlint/config-conventional": "^17.4.3",
    "@interactjs/dev-tools": "^1.10.27",
    "@intlify/unplugin-vue-i18n": "^6.0.0",
    "@pinia/testing": "^0.1.0",
    "@tsconfig/node22": "^22.0.0",
    "@types/jsdom": "^21.1.7",
    "@types/node": "^22.9.0",
    "@vitejs/plugin-vue": "^5.1.4",
    "@vitest/eslint-plugin": "1.1.7",
    "@vue/compiler-sfc": "^3.4.15",
    "@vue/eslint-config-prettier": "^10.1.0",
    "@vue/eslint-config-typescript": "^14.1.3",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.5.1",
    "autoprefixer": "^10.4.2",
    "canvas": "^2.9.1",
    "commit-and-tag-version": "^11.2.0",
    "cross-env": "^7.0.3",
    "cypress": "^13.15.1",
    "eslint-plugin-cypress": "^4.1.0",
    "eslint-plugin-vue": "^9.30.0",
    "husky": "^8.0.0",
    "jsdom": "^25.0.1",
    "npm-run-all2": "^7.0.1",
    "prettier": "^3.3.3",
    "rimraf": "^6.0.1",
    "sass-embedded": "^1.81.0",
    "start-server-and-test": "^2.0.8",
    "tsx": "^4.19.2",
    "typescript": "~5.6.3",
    "vite": "^5.4.10",
    "vite-plugin-vue-devtools": "^7.5.4",
    "vitest": "^2.1.4",
    "vue-tsc": "^2.1.10"
  }
}
